# Google Maps (Android)
# Used for custom map styling on Android
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Server API URL (used when DEV_FLAGS.USE_SERVER_API = true in src/config/devFlags.ts)
# Android emulator uses 10.0.2.2 to reach host machine's localhost
PALSAFAR_API_URL=http://localhost:5000/api

# Mobile crash reporting (Sentry). Prefer src/config/monitoring.local.ts for local
# overrides, or inject SENTRY_DSN at bundle/CI time.
SENTRY_DSN=https://<key>@o<org>.ingest.sentry.io/<project>
SENTRY_AUTH_TOKEN=
SENTRY_ENVIRONMENT=development
