<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Copy this file to GoogleService-Info.plist after registering an iOS app in
  Firebase Console (project: palsafar, bundle id: com.palsasafar).

  Steps:
  1. Firebase Console → Project settings → Add app → iOS
  2. Bundle ID: com.palsasafar
  3. Download GoogleService-Info.plist
  4. Place at ios/PalSafar/GoogleService-Info.plist (replace this example)
  5. Ensure it is listed in the Xcode target "Copy Bundle Resources"
  6. Upload APNs Auth Key (.p8) under Project settings → Cloud Messaging
-->
<plist version="1.0">
<dict>
	<key>CLIENT_ID</key>
	<string>REPLACE_ME.apps.googleusercontent.com</string>
	<key>REVERSED_CLIENT_ID</key>
	<string>com.googleusercontent.apps.REPLACE_ME</string>
	<key>API_KEY</key>
	<string>REPLACE_ME</string>
	<key>GCM_SENDER_ID</key>
	<string>701936644079</string>
	<key>PLIST_VERSION</key>
	<string>1</string>
	<key>BUNDLE_ID</key>
	<string>com.palsasafar</string>
	<key>PROJECT_ID</key>
	<string>palsafar</string>
	<key>STORAGE_BUCKET</key>
	<string>palsafar.firebasestorage.app</string>
	<key>IS_ADS_ENABLED</key>
	<false/>
	<key>IS_ANALYTICS_ENABLED</key>
	<false/>
	<key>IS_APPINVITE_ENABLED</key>
	<true/>
	<key>IS_GCM_ENABLED</key>
	<true/>
	<key>IS_SIGNIN_ENABLED</key>
	<true/>
	<key>GOOGLE_APP_ID</key>
	<string>1:701936644079:ios:REPLACE_ME</string>
</dict>
</plist>
